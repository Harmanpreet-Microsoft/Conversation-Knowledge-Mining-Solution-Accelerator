# This file explicitly blocks the problematic Azure DevOps registry
# and ensures only public npm registry is used

registry=https://registry.npmjs.org/

# Block access to the problematic registry by explicitly setting scopes
@azure:registry=https://registry.npmjs.org/
@fluentui:registry=https://registry.npmjs.org/
@testing-library:registry=https://registry.npmjs.org/
@types:registry=https://registry.npmjs.org/

# Ensure no authentication is attempted for public packages
always-auth=false
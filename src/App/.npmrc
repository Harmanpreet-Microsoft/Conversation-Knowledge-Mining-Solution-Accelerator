# FORCE PUBLIC NPM REGISTRY - BLOCK AZURE DEVOPS REGISTRY
registry=https://registry.npmjs.org/

# Explicitly block the problematic Azure DevOps registry
//pkgs.dev.azure.com/:_auth=BLOCKED
//pkgs.dev.azure.com/:always-auth=false

# Override ALL scoped packages to use public registry
@azure:registry=https://registry.npmjs.org/
@fluentui:registry=https://registry.npmjs.org/
@testing-library:registry=https://registry.npmjs.org/
@types:registry=https://registry.npmjs.org/
@microsoft:registry=https://registry.npmjs.org/

# Disable authentication for all public packages
always-auth=false
strict-ssl=true

# Additional settings to prevent fallback
audit-level=moderate
fund=false
save-exact=true
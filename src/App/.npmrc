# Force use of public npm registry only - override any organization settings
registry=https://registry.npmjs.org/

# Explicitly override all scoped packages to use public registry
@azure:registry=https://registry.npmjs.org/
@fluentui:registry=https://registry.npmjs.org/
@testing-library:registry=https://registry.npmjs.org/
@types:registry=https://registry.npmjs.org/

# Disable authentication for public packages
always-auth=false

# Block any fallback to private registries
audit-level=moderate
fund=false